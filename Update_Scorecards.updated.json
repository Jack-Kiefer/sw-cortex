              }
            },
            {
              "id": "chk-b36",
              "leftValue": "={{ $json.values[2][0] }}",
              "rightValue": "Core Product % with 2 Weeks of SA/FG",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a33b9aed-76cf-44e4-8a60-5f6b9a985627",
      "name": "4. Labels Match?",
