      "id": "4da45a18-65b0-4c7b-8cc3-36cfa91b03b2",
      "name": "1. Get Last Week Average",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1800, 120]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n// Avg item cost. The consolidated /scorecard/export response nests cost under\n// `cost` (cost.average_unit_price, etc.); the old single-cost endpoint returned\n// it at top level. Read from cost.* with a top-level fallback so either shape works.\nconst cost = data.cost || data;\nlet costValue = cost.average_unit_price ? parseFloat(cost.average_unit_price) : 0;\nif (isNaN(costValue)) costValue = 0;\nconst formattedCost = `$${costValue.toFixed(2)}`;\n// Coverage percentages\nconst overall = data.overall || {};\nconst orderedPct = `${(overall.ordered && overall.ordered.pct != null) ? overall.ordered.pct : 0}%`;\nconst packedPct  = `${(overall.packed  && overall.packed.pct  != null) ? overall.packed.pct  : 0}%`;\nreturn [{ json: {\n  formattedCost, orderedPct, packedPct,\n  periodLabel: cost.period_label,\n  totalItems: cost.total_items_shipped,\n} }];"
      },
      "id": "9863c003-4abc-4336-bb68-4c79696cc0ae",
      "name": "2. Format Cost Value",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1560, 120]
    },
    {
      "parameters": {
        "url": "https://sheets.googleapis.com/v4/spreadsheets/17J0Uqqd0dkaS6-3TCCB_TtP1eZg6xbdC0IWThrOH5FM/values/Scorecard26!B34:B36",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "options": {}
      },
      "id": "f5f6fa22-3f1a-44a7-91cf-29da31db8eaa",
      "name": "3. Read B34:B36",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1320, 120],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YY0aKH375lw428rC",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "chk-b34",
              "leftValue": "={{ $json.values[0][0] }}",
              "rightValue": "Avg Item Cost",
              "operator": {
                "type": "string",
