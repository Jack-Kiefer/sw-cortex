      "position": [-1080, 120]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "https://sheets.googleapis.com/v4/spreadsheets/17J0Uqqd0dkaS6-3TCCB_TtP1eZg6xbdC0IWThrOH5FM/values/Scorecard26!F34:F36?valueInputOption=USER_ENTERED",
        "authentication": "predefinedCredentialType",
