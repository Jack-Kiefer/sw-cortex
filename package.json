{
  "name": "sw-cortex",
  "version": "1.0.0",
  "description": "Personal work intelligence platform - Slack search, databases, knowledge base via MCP",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "github:serve": "tsx src/mcp-servers/github/index.ts",
    "db:serve": "tsx src/mcp-servers/db/index.ts",
    "discoveries:serve": "tsx src/mcp-servers/discoveries/index.ts",
    "slack-search:serve": "tsx src/mcp-servers/slack-search/index.ts",
    "logs:serve": "tsx src/mcp-servers/logs/index.ts",
    "qdrant:init": "tsx scripts/qdrant-init.ts",
    "qdrant:init-discoveries": "tsx scripts/init-discoveries-collection.ts",
    "qdrant:status": "tsx scripts/qdrant-status.ts",
    "slack:sync": "tsx scripts/sync-slack-encrypted.ts",
    "slack:sync-plaintext": "tsx scripts/sync-slack-messages.ts",
    "meetings:sync": "tsx scripts/sync-meetings.ts",
    "plans:sync": "tsx scripts/sync-meetings.ts -- --plans-only",
    "knowledge:sync": "tsx scripts/sync-meetings.ts",
    "sync:all": "tsx scripts/sync-meetings.ts && tsx scripts/sync-slack-encrypted.ts",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "setup": "tsx scripts/setup.ts",
    "generate:mcp": "tsx scripts/generate-mcp-config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^22.0.1",
    "@qdrant/js-client-rest": "^1.8.0",
    "@slack/bolt": "^3.17.0",
    "@slack/web-api": "^7.0.0",
    "better-sqlite3": "^9.4.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "mysql2": "^3.9.0",
    "openai": "^6.15.0",
    "p-limit": "^7.2.0",
    "pg": "^8.11.0",
    "ssh2": "^1.15.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/ssh2": "^1.15.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.52.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
