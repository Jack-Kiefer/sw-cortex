# sw-cortex Environment Variables
# Copy to .env and fill in values

# =============================================================================
# SLACK (Required for Slack sync + search)
# =============================================================================

# User token (xoxp-*) — needed to read YOUR message history
SLACK_USER_TOKEN=xoxp-your-user-token

# Bot token (xoxb-*) — for sending messages
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Encryption key for sensitive data stored in Qdrant (hex string, 64 chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Your Slack user ID
SLACK_USER_ID=U0123456789

# =============================================================================
# QDRANT (Required for semantic search)
# =============================================================================

QDRANT_URL=https://your-instance.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# OPENAI (Required for generating embeddings)
# =============================================================================

OPENAI_API_KEY=sk-your-openai-key

# =============================================================================
# GITHUB (Optional — for GitHub MCP server)
# =============================================================================

GITHUB_TOKEN=ghp-your-token

# JSON array of repos to access via MCP (read-only)
# Format: [{"owner":"org","repo":"name","description":"optional"}]
GITHUB_REPOS=[]

# =============================================================================
# DATABASES — MySQL (Optional — for database MCP server)
# =============================================================================

WISHDESK_DB_HOST=
WISHDESK_DB_PORT=3306
WISHDESK_DB_USER=
WISHDESK_DB_PASSWORD=
WISHDESK_DB_NAME=

SUGARWISH_DB_HOST=
SUGARWISH_DB_PORT=3306
SUGARWISH_DB_USER=
SUGARWISH_DB_PASSWORD=
SUGARWISH_DB_NAME=

MANAGE_DB_HOST=
MANAGE_DB_PORT=3306
MANAGE_DB_USER=
MANAGE_DB_PASSWORD=
MANAGE_DB_NAME=

# =============================================================================
# DATABASES — PostgreSQL (Optional — for database MCP server)
# =============================================================================

ODOO_DB_HOST=
ODOO_DB_PORT=5432
ODOO_DB_USER=
ODOO_DB_PASSWORD=
ODOO_DB_NAME=

ODOO_STAGING_DB_HOST=
ODOO_STAGING_DB_PORT=5432
ODOO_STAGING_DB_USER=
ODOO_STAGING_DB_PASSWORD=
ODOO_STAGING_DB_NAME=

RETOOL_DB_HOST=
RETOOL_DB_PORT=5432
RETOOL_DB_USER=
RETOOL_DB_PASSWORD=
RETOOL_DB_NAME=

# =============================================================================
# SSH TUNNEL (Optional — for remote database access)
# =============================================================================

LIVE_SSH_TUNNEL=false
LIVE_SSH_HOST=
LIVE_SSH_USER=
LIVE_SSH_KEY_PATH=~/.ssh/id_rsa
LIVE_SSH_TUNNEL_PORT=
