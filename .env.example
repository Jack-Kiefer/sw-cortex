# sw-cortex Environment Variables
# Copy to .env and fill in values

# =============================================================================
# SLACK (Required for Slack sync + search)
# =============================================================================

# User token (xoxp-*) — needed to read YOUR message history
SLACK_USER_TOKEN=xoxp-your-user-token

# Bot token (xoxb-*) — for sending messages from sw-cortex services
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Bot token + team ID for the jack-slack MCP server (separate Slack app)
JACK_SLACK_BOT_TOKEN=xoxb-your-jack-slack-bot-token
SLACK_TEAM_ID=T0123456789

# Encryption key for sensitive data stored in Qdrant (hex string, 64 chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Your Slack user ID
SLACK_USER_ID=U0123456789

# =============================================================================
# QDRANT (Required for semantic search)
# =============================================================================

QDRANT_URL=https://your-instance.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# OPENAI (Required for generating embeddings)
# =============================================================================

OPENAI_API_KEY=sk-your-openai-key

# =============================================================================
# GITHUB (Optional — for GitHub MCP server)
# =============================================================================

GITHUB_TOKEN=ghp-your-token

# JSON array of repos to access via MCP (read-only)
# Format: [{"owner":"org","repo":"name","description":"optional"}]
GITHUB_REPOS=[]

# =============================================================================
# DATABASES — MySQL (Optional — for database MCP server)
# =============================================================================

WISHDESK_DB_HOST=
WISHDESK_DB_PORT=3306
WISHDESK_DB_USER=
WISHDESK_DB_PASSWORD=
WISHDESK_DB_NAME=
# wishdesk routes through the shared LIVE_SSH bastion (see SSH TUNNEL below).

WISHDESK_DEV_DB_HOST=
WISHDESK_DEV_DB_PORT=3306
WISHDESK_DEV_DB_USER=
WISHDESK_DEV_DB_PASSWORD=
WISHDESK_DEV_DB_NAME=

# Laravel Live (SERP production) — MCP key: laravel_live
SUGARWISH_DB_HOST=
SUGARWISH_DB_PORT=3306
SUGARWISH_DB_USER=
SUGARWISH_DB_PASSWORD=
SUGARWISH_DB_NAME=

# Manage (Laravel staging) — MCP key: manage
MANAGE_DB_HOST=
MANAGE_DB_PORT=3306
MANAGE_DB_USER=
MANAGE_DB_PASSWORD=
MANAGE_DB_NAME=

# Local — MCP key: local
# LOCAL_DB_NAME is the actual MySQL database name on your machine — pick whatever
# your local Laravel/SERP dev DB is called (e.g. serp_local, my_app_dev).
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3307
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=
LOCAL_DB_NAME=

# =============================================================================
# DATABASES — PostgreSQL (Optional — for database MCP server)
# =============================================================================

ODOO_DB_HOST=
ODOO_DB_PORT=5432
ODOO_DB_USER=
ODOO_DB_PASSWORD=
ODOO_DB_NAME=

ODOO_STAGING_DB_HOST=
ODOO_STAGING_DB_PORT=5432
ODOO_STAGING_DB_USER=
ODOO_STAGING_DB_PASSWORD=
ODOO_STAGING_DB_NAME=

RETOOL_DB_HOST=
RETOOL_DB_PORT=5432
RETOOL_DB_USER=
RETOOL_DB_PASSWORD=
RETOOL_DB_NAME=

# =============================================================================
# SSH TUNNEL (Optional — one shared bastion for the private-RDS databases)
# =============================================================================
#
# Only `wishdesk` and `laravel_live` use this tunnel — they live on the private
# AWS RDS, which is reachable ONLY through the bastion. Every other remote DB
# (Odoo/Retool cloud, the Hetzner hosts) is public and connects directly, so it
# needs nothing here. All tunneled DBs share ONE SSH connection and ONE local
# forward port.
#
# Set LIVE_SSH_TUNNEL=false to disable the tunnel entirely (both DBs then try a
# direct connect, which fails against the private RDS — only useful when running
# against a locally-reachable stand-in).
LIVE_SSH_TUNNEL=true
LIVE_SSH_HOST=          # bastion host/IP
LIVE_SSH_PORT=22        # bastion SSH port (default 22)
LIVE_SSH_USER=          # bastion SSH user
LIVE_SSH_KEY_PATH=~/.ssh/id_rsa   # path to the private key for the bastion
# Fixed local port the tunnel binds (so /start-day's health check can probe it).
# Falls back to a random free port if unset or already in use.
LIVE_SSH_TUNNEL_PORT=13306

# Deprecated alias: WISHDESK_USE_SSH=false disables the tunnel for wishdesk only.
# Prefer LIVE_SSH_TUNNEL for the shared toggle.
WISHDESK_USE_SSH=

# N8N — live self-hosted n8n instance, read via its REST API by the n8n MCP server.
N8N_HOST=http://localhost:5678      # base URL of the instance
N8N_API_KEY=                        # personal API key (n8n → Settings → n8n API)
